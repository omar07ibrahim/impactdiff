{
  "name": "impactdiff",
  "version": "0.0.0",
  "private": true,
  "description": "Task-aware multimodal visual regression research lab",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omar07ibrahim/impactdiff.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test --test-concurrency=1 'dist/test/**/*.test.js'",
    "coverage": "npm run build && node --test --test-concurrency=1 --experimental-test-coverage 'dist/test/**/*.test.js'",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "ajv": "8.20.0",
    "canonicalize": "3.0.0",
    "pngjs": "7.0.0"
  },
  "peerDependencies": {
    "@playwright/test": "1.61.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@types/pngjs": "6.0.5",
    "json-schema-to-ts": "3.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3"
  }
}
